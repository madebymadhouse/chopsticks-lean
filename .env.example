# chopsticks-lean environment example

STORAGE_DRIVER=postgres

DISCORD_TOKEN=__REPLACE_ME__
CLIENT_ID=__REPLACE_ME__
BOT_OWNER_IDS=__YOUR_DISCORD_USER_ID__

POSTGRES_URL=postgresql://chopsticks:changeme@127.0.0.1:5432/chopsticks
DATABASE_URL=postgresql://chopsticks:changeme@127.0.0.1:5432/chopsticks
REDIS_URL=redis://127.0.0.1:6379

# Lean runtime switches. Keep these disabled.
DASHBOARD_ENABLED=false
AGENTS_ENABLED=false
MUSIC_ENABLED=false

# Health endpoint
HEALTH_PORT=9100
HEALTH_METRICS_TOKEN=
HEALTH_DEBUG_ENABLED=false
HEALTH_DEBUG_TOKEN=

# Slash command deploy helpers
DEV_GUILD_ID=

# Bot identity overrides (optional)
BOT_NAME=chopsticks-lean
BOT_TAGLINE=Lean Discord bot for moderation and voice rooms
BOT_FOOTER={botname}

# Optional API keys used by some retained commands
NASA_API_KEY=DEMO_KEY
HUGGINGFACE_API_KEY=
GITHUB_TOKEN=
STEAM_API_KEY=
